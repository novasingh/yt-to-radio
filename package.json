{
  "name": "youtube-radio-streamer",
  "version": "1.0.0",
  "description": "Stream audio from YouTube using yt-dlp and ffmpeg to multiple local listeners",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "install:force": "npm install --force"
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "fluent-ffmpeg": "^2.1.3",
    "jsonwebtoken": "^9.0.2",
    "sqlite3": "^6.0.1",
    "youtube-dl-exec": "^3.1.7"
  }
}
